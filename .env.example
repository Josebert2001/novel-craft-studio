# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` — it is gitignored.

# ── Client (Vite) ──────────────────────────────────────────
# Public Supabase project URL and anon key. These ship to the browser, so
# they must be the ANON key (never service_role). RLS policies protect data.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key

# ── Capacitor (optional) ───────────────────────────────────
# When set, Capacitor loads the app from this URL instead of bundled assets.
# Leave blank for production mobile builds so the app runs from `dist/`.
CAP_SERVER_URL=

# ── Supabase edge function secrets (set via `supabase secrets set`) ──
# SUPABASE_URL               # provisioned automatically
# SUPABASE_ANON_KEY          # provisioned automatically
# SUPABASE_SERVICE_ROLE_KEY  # provisioned automatically
# GEMINI_API_KEY=            # your Google Gemini API key
# ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
